# ─── Kip It Real — Environment Variables ─────────────────────────────────────
#
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and never committed.
#
# On Vercel: add these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Admin panel password.
# Protects /admin/* routes and the sync/import API endpoints.
# Set any strong password — there is no account; this is the single secret.
ADMIN_SECRET=changeme

# (Optional) Override the Google Sheets catalog CSV URL.
# Defaults to the hard-coded published URL in lib/catalog/sheetsSync.ts.
# Only set this if you move the sheet or create a second one.
# SHEETS_CATALOG_URL=https://docs.google.com/spreadsheets/d/e/YOUR_ID/pub?output=csv
